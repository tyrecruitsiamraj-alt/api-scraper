# AUTO-POST - ตัวอย่าง .env
# คัดลอกเป็น .env แล้วกรอกค่าจริง

# Port สำหรับ Web Admin (default: 3000)
PORT=3000
# ถ้ารัน `playwright test postAll` จากเครื่อง (ไม่ผ่านปุ่มใน Admin) ให้ตั้งให้ตรงพอร์ตเซิร์ฟเวอร์
# เช่น http://localhost:3002 — ไม่ตั้งจะบันทึก Post Log ไปที่พอร์ต 3000 อาจไม่เข้า DB
# RUN_LOG_API_URL=http://localhost:3000

# PostgreSQL Database
DATABASE_URL="postgresql://user:password@host:5432/database?schema=so-autopost_jobs&sslmode=disable"
# schema ของ autopost — ตั้ง so_autopost_apiscraper เพื่อแยกจากทีม (บัญชี/คิวคนละชุด)
# so_autopost_jobs = ของทีมเดิม (อย่าใช้ ถ้าไม่อยากชนกัน)
DB_SCHEMA=so_autopost_apiscraper
# โหมดเว็บสาธารณะ (เช่น Vercel) + worker บนเครื่องจริง
# ฝั่ง server (Vercel) ต้องตั้ง token นี้
# POST_WORKER_TOKEN=change_me_long_random_token
#
# --- ประตูเข้า UI (ปิดรูรั่ว: AUTO-POST บน Vercel เปิดโล่ง ใครรู้ URL ก็สั่งโพสต์ได้) ---
# ตั้งค่านี้บน server (Vercel) แล้วคอนโซล Next.js ต้องตั้งค่าเดียวกัน (AUTOPOST_ACCESS_TOKEN)
# เพื่อฝัง token ให้ iframe — เข้าถึง AUTO-POST ได้เฉพาะผ่านคอนโซลที่ล็อกอิน Azure แล้ว
# ไม่ตั้ง = เปิดเหมือนเดิม (โหมด dev/เครื่องส่วนตัว). ยกเว้น health/worker/run-logs เสมอ
# AUTOPOST_ACCESS_TOKEN=change_me_long_random_token
#
# --- โหมดโพสต์ (สำคัญ) ---
# • รัน npm start บน PC แล้วเปิด Admin ที่ http://localhost:PORT — ถ้าไม่ตั้ง POST_REMOTE_WORKER และไม่มี env VERCEL=1
#   กด «โพสต์» จะเปิด Google Chrome บนเครื่องนี้ทันที
# • บน Vercel (มี VERCEL=1) หรือตั้ง POST_REMOTE_WORKER=1 — กดโพสต์ = เข้าคิวใน DB เท่านั้น ต้องรัน npm run worker:post บน PC
# ถ้าต้องการบังคับคิวแม้รันเซิร์ฟเวอร์ในเครื่อง (ใช้ DB เดียวกับ Vercel):
# POST_REMOTE_WORKER=1

# Credentials สำหรับ Users (keyed by env_key ในตาราง users)
# ใช้รูปแบบ USER_{env_key}_EMAIL และ USER_{env_key}_PASSWORD
USER_1_EMAIL=user1@example.com
USER_1_PASSWORD=your_password_here

USER_2_EMAIL=user2@example.com
USER_2_PASSWORD=your_password_here

# ฝั่งเครื่อง Worker (Local PC)
# WORKER_API_BASE=https://soworkautopost.vercel.app
# POST_WORKER_TOKEN=change_me_long_random_token
# npm run worker:post = supervisor รีสตาร์ทอัตโนมัติเมื่อ worker ล้ม — หน่วงก่อนรีสตาร์ท (ms)
# WORKER_SUPERVISOR_RESTART_MS=5000
# รัน worker โดยไม่มี supervisor: npm run worker:post:raw
# งานโพสต์พร้อมกัน (แต่ละงาน ≈ Chrome 1 ตัว) — ค่าเริ่มต้นในโค้ด 24 / เพดาน 48 (สูงสุดในโค้ด 96)
# โดนจับว่าเป็นบอทบ่อย: ลดเป็น 1–3 บัญชีละ Chrome
# WORKER_CONCURRENCY=24
# WORKER_CONCURRENCY_MAX=48
#
# --- ชื่อเครื่องสำหรับ pin บัญชี→เครื่อง (กันบัญชีสลับ IP โดยไม่ใช้ proxy) ---
# เว้นว่าง = ใช้ hostname ของเครื่อง (เช่น SONB-RM017). ตั้งเองได้ถ้าอยากชื่อจำง่าย
# ต้องตรงกับค่าที่กรอกในหน้า "บัญชี Facebook > ผูกบัญชีกับเครื่อง"
# WORKER_NAME=SONB-RM017
# --- พฤติกรรมโพสต์แบบมนุษย์ (ลด bot detection) ---
# HUMAN_BEHAVIOR_ENABLED=1
# ความเร็วพิมพ์ (ms/ตัวอักษร) — default เร็ว ~พิมพ์ 50–70 คำ/นาที
# HUMAN_TYPE_DELAY_MIN_MS=12
# HUMAN_TYPE_DELAY_MAX_MS=28
# ข้อความยาวกว่า N ตัว → พิมพ์เป็นชิ้น (เร็วกว่าทีละตัว)
# HUMAN_TYPE_CHUNK_CHARS=80
# HUMAN_TYPE_CHUNK_MIN=5
# HUMAN_TYPE_CHUNK_MAX=12
# หน่วงระหว่างกลุ่ม (วินาที) — default 60–150 วินาที (~1–2.5 นาที)
# HUMAN_POST_DELAY_MIN_SEC=60
# HUMAN_POST_DELAY_MAX_SEC=150
# พักหลังโพสต์ครบ batch (วินาที) — default 5–15 นาที
# HUMAN_BATCH_SIZE=5
# HUMAN_BATCH_BREAK_MIN_SEC=300
# HUMAN_BATCH_BREAK_MAX_SEC=900
# ปรับแคปชั่นเล็กน้อยต่อกลุ่ม (เนื้อหาเดิม) — ปิด: CAPTION_VARIATION_ENABLED=0
#
# --- แผนโพสต์รายวัน (กันโดน Facebook block) ---
# เพดานโพสต์ต่อบัญชีต่อวัน (นับเวลาไทย; override รายบัญชีได้ที่คอลัมน์ users.daily_cap)
# POST_DAILY_CAP=15
# บัญชีใหม่วอร์มอัตโนมัติ: สัปดาห์แรก 5/วัน → 8 → 12 → เต็มเพดาน (ปิด: POST_WARMUP_DISABLED=1)
# ห้ามโพสต์งานเดิมลงกลุ่มเดิมซ้ำภายในกี่วัน (นับรวมทุกบัญชี)
# POST_REPOST_MIN_GAP_DAYS=2
# สัดส่วนโควต้าที่กันไว้ลองกลุ่มที่ยังไม่เคยโพสต์ (ที่เหลือ = กลุ่มที่เคยได้เบอร์/คอมเมนต์ก่อน)
# POST_EXPLORE_SHARE=0.2
# circuit breaker: โพสต์ไม่สำเร็จติดกันกี่กลุ่ม → พักบัญชีอัตโนมัติกี่ชั่วโมง
# POST_FAIL_STREAK_LIMIT=5
# POST_PAUSE_HOURS=24
#
# --- รอบโพสต์อัตโนมัติประจำวัน (worker ยิงเอง — ใช้ได้แม้ server อยู่บน Vercel) ---
# AUTO_POST_DAILY_ENABLED=1
# AUTO_POST_TZ=Asia/Bangkok
# AUTO_POST_HOUR=8
# AUTO_POST_MINUTE=0
#
# --- เวลาโพสต์ (Playwright ปิด Chrome เมื่อเทสต์ timeout) ---
# เทสต์ postAll — default 6 ชม. (21600000 ms); สูงสุด 12 ชม.
# PLAYWRIGHT_GLOBAL_TIMEOUT_MS=21600000
#
# --- กันคิวค้าง / งานหยุดกลางทาง ---
# งานโพสต์หนึ่งงานนานสุดเท่าไรแล้วฆ่า Playwright (ms) — default 8 ชม. (ควรมากกว่า PLAYWRIGHT_GLOBAL_TIMEOUT_MS)
# WORKER_POST_JOB_MAX_MS=28800000
# งาน status=running ใน DB เกินกี่นาทีถือว่าค้าง → ปิดเป็น failed (worker เรียก sweep ทุก 2 นาที)
# POST_RUN_STALE_MINUTES=180
# WORKER_SWEEP_INTERVAL_MS=120000
# WORKER_HEARTBEAT_MS=60000
# งานเก็บ Comment พร้อมกัน (ค่าเริ่มต้น 4)
# WORKER_COLLECT_CONCURRENCY=4
# งานเก็บ Comment หนึ่งงานนานสุด (ms) — default 6 ชม.
# WORKER_COLLECT_JOB_MAX_MS=21600000
# งาน collect status=running ค้างเกินกี่นาทีให้ sweep เป็น failed
# COLLECT_RUN_STALE_MINUTES=180
# Auto collect ทุกเช้า (ดึงโพสต์ "เมื่อวาน" ทุกบัญชี แล้วเข้าคิวเก็บ Comment อัตโนมัติ)
# AUTO_COLLECT_ENABLED=1
# AUTO_COLLECT_TZ=Asia/Bangkok
# AUTO_COLLECT_HOUR=7
# AUTO_COLLECT_MINUTE=15
# มอนิเตอร์คิวแยกเทอร์มินัล: npm run worker:watch
# WORKER_WATCH_POLL_MS=45000

# User 4 (จาก User4.json / User4Worker.json - structure เดียวกับ User1-8)
USER_4_EMAIL=your_phone_or_email
USER_4_PASSWORD=your_password_here

# Facebook API - สำหรับดึงชื่อกลุ่มจาก Group ID (ปุ่ม "ดึงชื่อจาก FB" ในฟอร์ม Groups)
# ใส่ตาม User - ใช้บัญชีที่เข้ากลุ่มนั้นได้ (หรือกรอกในฟอร์ม User > FB Access Token)
# USER_1_FB_ACCESS_TOKEN=your_token_for_user1
# USER_2_FB_ACCESS_TOKEN=your_token_for_user2
