# Platform: jobbkk | jobthai | both
# เปลี่ยนค่านี้เพื่อเลือก default (ยังเลือกซ้ำใน popup ได้)
SCRAPE_PLATFORM=jobbkk

JOBBKK_HOME_URL=https://www.jobbkk.com/home

JOBBKK_EMPLOYER_LOGIN_URL=https://www.jobbkk.com/login/employer_login

JOBBKK_RESUME_SEARCH_URL=https://www.jobbkk.com/resumes/premium

JOBBKK_USERNAME=

JOBBKK_PASSWORD=

JOBTHAI_LOGIN_URL=https://auth.jobthai.com/companies/login?client_id=NlnJk4E3pLR2TBGu930OQXJAiy9mJ7sWpZ8w8RAq&response_type=code&redirect_uri=https%3A%2F%2Fwww.jobthai.com%2Fcallback&scope=login&l=th&type=company

JOBTHAI_RESUME_SEARCH_URL=https://www3.jobthai.com/findresume/findresume.php?l=th

JOBTHAI_USERNAME=

JOBTHAI_PASSWORD=

HEADLESS=false

DEFAULT_MAX_CANDIDATES=15

PAUSE_AT_END=false



# false = เร็วขึ้น (ไม่บันทึก PNG/HTML ทุกขั้นตอน) | true = debug ละเอียด

DEBUG_MODE=false



# ช่วงหน่วงระหว่าง candidate (ms) — สุ่ม jitter ช่วยลดความเสี่ยงโดน block

# ถ้าไม่ตั้ง DELAY_MS_MIN/MAX จะใช้ DELAY_MS เป็นค่าต่ำสุด และ +800ms เป็นสูงสุด

DELAY_MS=1500

DELAY_MS_MIN=1200

DELAY_MS_MAX=2200



# หน่วงระหว่างดาวน์โหลดไฟล์แนบต่อ candidate

ATTACHMENT_DELAY_MS=400

ATTACHMENT_DELAY_JITTER_MS=250



# รอ DOM พร้อม parse หลังโหลดหน้า resume (ms)

PAGE_READY_MS=350

