# ===== api-scraper (Docker, DB-backed, multi-connector) =====

# --- PostgreSQL (external) ---
# either DATABASE_URL ...
# DATABASE_URL=postgres://root:PASSWORD@94.74.115.204:5432/ocr_service
# ... or individual vars:
PGHOST=94.74.115.204
PGPORT=5432
PGUSER=root
PGPASSWORD=            # <<< ใส่รหัสผ่าน Postgres จริงตรงนี้
PGDATABASE=ocr_service
DB_SCHEMA=so-candidate-data

# --- App secret (เข้ารหัส password ของ connector ด้วย AES-256-GCM) ---
APP_ENCRYPTION_KEY=    # <<< สุ่มสตริงยาว ๆ แล้วเก็บให้ดี (ห้ามเปลี่ยนหลังมี connector แล้ว)

# --- Search criteria (worker ใช้ค่านี้ทุก connector; override ได้ตอน POST /runs) ---
POSITION=พนักงานขับรถ
KEYWORD=
MAX_CANDIDATES=15
PROVINCE=              # ชื่อจังหวัดไทย เช่น นนทบุรี (map เป็น id อัตโนมัติ)
SALARY_MIN=
SALARY_MAX=
AGE_MIN=
AGE_MAX=
GENDER=               # ชาย | หญิง | (ว่าง=ทุกเพศ)

# --- Runtime / anti-ban ---
HEADLESS=true
DEBUG=false
# หน่วงสุ่มระหว่าง request หน้า detail (ms) — ยิ่งสูงยิ่งปลอดภัยจากการโดน ban
REQUEST_DELAY_MIN_MS=2500
REQUEST_DELAY_MAX_MS=6000
PORT=8080

# --- (ทางเลือก) ใช้เฉพาะ standalone scrape.js โหมดเก่า ---
JOBBKK_USERNAME=
JOBBKK_PASSWORD=

# --- CAPTCHA fallback (ปกติ JobBKK login ไม่เจอ — เว้นว่างได้) ---
CAPTCHA_PROVIDER=
CAPTCHA_API_KEY=
