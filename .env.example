# ===== api-scraper (Docker, DB-backed, multi-connector) =====

# --- PostgreSQL (external) ---
# either DATABASE_URL ...
# DATABASE_URL=postgres://root:PASSWORD@94.74.115.204:5432/ocr_service
# ... or individual vars:
PGHOST=94.74.115.204
PGPORT=5432
PGUSER=root
PGPASSWORD=            # <<< ใส่รหัสผ่าน Postgres จริงตรงนี้
PGDATABASE=ocr_service
DB_SCHEMA=so-candidate-data
# schema ฝั่ง autopost ที่ worker (measure) อ่าน post_logs — แยกต่อ project
# ไม่ตั้ง = so_autopost_jobs (เดิม/รวมกับทีม); ตั้ง = so_autopost_apiscraper (แยกของ project นี้)
AUTOPOST_SCHEMA=so_autopost_apiscraper

# --- App secret (เข้ารหัส password ของ connector ด้วย AES-256-GCM) ---
APP_ENCRYPTION_KEY=    # <<< สุ่มสตริงยาว ๆ แล้วเก็บให้ดี (ห้ามเปลี่ยนหลังมี connector แล้ว)

# --- Search criteria (worker ใช้ค่านี้ทุก connector; override ได้ตอน POST /runs) ---
POSITION=พนักงานขับรถ
KEYWORD=
MAX_CANDIDATES=15
PROVINCE=              # ชื่อจังหวัดไทย เช่น นนทบุรี (map เป็น id อัตโนมัติ)
SALARY_MIN=
SALARY_MAX=
AGE_MIN=
AGE_MAX=
GENDER=               # ชาย | หญิง | (ว่าง=ทุกเพศ)

# --- Runtime / anti-ban ---
HEADLESS=true
DEBUG=false
# หน่วงสุ่มระหว่าง request หน้า detail (ms) — ยิ่งสูงยิ่งปลอดภัยจากการโดน ban
REQUEST_DELAY_MIN_MS=2500
REQUEST_DELAY_MAX_MS=6000
PORT=8080

# --- (ทางเลือก) ใช้เฉพาะ standalone scrape.js โหมดเก่า ---
JOBBKK_USERNAME=
JOBBKK_PASSWORD=

# --- CAPTCHA fallback (ปกติ JobBKK login ไม่เจอ — เว้นว่างได้) ---
CAPTCHA_PROVIDER=
CAPTCHA_API_KEY=

# --- ขยายตำแหน่งใกล้เคียงอัตโนมัติเมื่อหาผู้สมัครไม่ครบ target (AI จัด Job Family) ---
# เว้นว่าง = ปิด feature (scrape ทำงานปกติ ไม่ขยาย). ใส่ key เพื่อเปิด.
ANTHROPIC_API_KEY=
JOBFAMILY_MODEL=claude-haiku-4-5   # โมเดลที่ใช้จัด Job Family (เว้นว่าง=ค่านี้)
MAX_ADJACENT_ROUNDS=6              # จำกัดจำนวนรอบขยายต่อ task (กันเปิด browser วนไม่จบ)

# --- Content Orchestrator: รับใบขอจาก ERP (SQL Server) — worker query แล้ว sync เข้า Postgres ---
# เว้น MSSQL_HOST = ปิด intake (feature อื่นไม่พัง). รันด้วย `npm run erp:sync` (บนเครื่องที่ต่อ ERP ได้)
MSSQL_HOST=
MSSQL_PORT=1433
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_DATABASE=
MSSQL_ENCRYPT=false
MSSQL_TRUST_CERT=true

# --- Content Orchestrator: สร้างรูปด้วย AI (เว้นว่าง=ปิดการสร้างรูป, ข้อความยังทำได้ด้วย ANTHROPIC) ---
OPENAI_API_KEY=
CONTENT_IMAGE_MODEL=gpt-image-1
CONTENT_TEXT_MODEL=claude-sonnet-5   # โมเดลคิด caption/brief (เว้นว่าง=ค่านี้)
CONTENT_IMAGE_SIZE=1024x1024         # ขนาดรูป AI (เว้นว่าง=ค่านี้)
CONTENT_IMAGE_PROVIDER=openai        # provider สร้างรูป (ตอนนี้รองรับ openai)

# --- ทางเลือกฟรี: คิดข้อความด้วย Ollama server บริษัท (ไม่ต้องมี ANTHROPIC key) ---
# ไม่ตั้ง CONTENT_TEXT_PROVIDER = เลือกอัตโนมัติ (มี ANTHROPIC key→claude, ไม่มีแต่มี OLLAMA→ollama)
# หมายเหตุ: Ollama คิดได้เฉพาะข้อความ — รูปยังต้อง OPENAI_API_KEY
CONTENT_TEXT_PROVIDER=               # anthropic | ollama | เว้นว่าง=อัตโนมัติ
OLLAMA_BASE_URL=                     # เช่น http://110.49.94.180:11434 (server ภายในบริษัท)
OLLAMA_MODEL=qwen3.5:9b              # โมเดลบน server (เว้นว่าง=ค่านี้)

# --- Content Orchestrator เฟส 4: เกณฑ์วัดผล engagement (worker measure) ---
ENGAGE_HIGH_SCORE=5                   # คะแนน >= นี้ = คนสนใจเยอะ (เสร็จ+บันทึกแนว); ต่ำกว่า = คิดใหม่
ENGAGE_LEAD_WEIGHT=2                  # น้ำหนักคนทัก: score = คอมเมนต์ + คนทัก*ค่านี้
