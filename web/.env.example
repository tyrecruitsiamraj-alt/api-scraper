# ===== So Recruit web (Next.js) =====

# --- NextAuth ---
NEXTAUTH_URL=http://localhost:3100
# openssl rand -base64 32
NEXTAUTH_SECRET=

# --- Azure AD (Entra ID) ---
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# --- PostgreSQL (same DB as the scraper) ---
PGHOST=94.74.115.204
PGPORT=5432
PGUSER=root
PGPASSWORD=
PGDATABASE=ocr_service
DB_SCHEMA=so-candidate-data

# --- Connector credential encryption (AES-256-GCM) ---
# MUST be identical to api-scraper/.env APP_ENCRYPTION_KEY, or the scraper worker
# cannot decrypt connector passwords created from the web UI. Never change once set.
APP_ENCRYPTION_KEY=

# --- Ollama (attachment extraction; used by the worker, listed here for ref) ---
OLLAMA_HOST=http://110.49.94.180:11434
OCR_MODEL=scb10x/typhoon-ocr1.5-3b:latest
